FROM python:3.11-slim AS base

LABEL org.opencontainers.image.title="Biona Lab"
LABEL org.opencontainers.image.description="Biona AI Infrastructure — Training and Export Pipeline"
LABEL org.opencontainers.image.vendor="Biona AI Infrastructure"

ARG VERSION=dev
ARG BUILD_DATE
ARG GIT_SHA

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    VERSION=${VERSION} \
    BUILD_DATE=${BUILD_DATE} \
    GIT_SHA=${GIT_SHA}

# ── System deps ───────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libsndfile1 \
    ffmpeg \
    curl \
    && rm -rf /var/lib/apt/lists/*

# ── Non-root user ─────────────────────────────────────────────────────────────
RUN groupadd -r biona && useradd -r -g biona biona
WORKDIR /app
RUN chown -R biona:biona /app

# ── Python dependencies (cached layer) ───────────────────────────────────────
COPY --chown=biona:biona biona/lab/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── Application code ──────────────────────────────────────────────────────────
COPY --chown=biona:biona biona/lab/ .
COPY --chown=biona:biona biona/lab/biona_contract.json .

USER biona

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["python", "-m", "uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8080"]
